# Safe defaults. Live publishing remains off until explicitly enabled.
RUN_LIGHTER_TIMEZONE=Australia/Sydney
RUN_LIGHTER_SITE_URL=https://arav1oli.github.io/runlighter
CAMPAIGN_START_DATE=
CAMPAIGN_DAYS=14
CONTINUOUS_CONTENT=false
CONTENT_STAGE_TIME=05:00
CONTENT_PUBLISH_TIME=07:00
AUTO_PUBLISH=false
INSTAGRAM_AUTO_PUBLISH=false
CONTENT_KILL_SWITCH=false
DRY_RUN=true
TOPIC_SIMILARITY_THRESHOLD=0.82
PROMOTION_THRESHOLD=80
MAX_RETRIES=3
PUBLISH_TIMEOUT_SECONDS=300
CAPTION_MIN_WORDS=80
CAPTION_MAX_WORDS=180
ARTICLE_MIN_WORDS=700
ARTICLE_MAX_WORDS=1300

# Providers: mock, openai, none
TEXT_PROVIDER=mock
IMAGE_PROVIDER=mock
RESEARCH_PROVIDER=none
OPENAI_API_KEY=
TEXT_MODEL=gpt-5.6
IMAGE_MODEL=gpt-image-2

# Meta Instagram Content Publishing API.
# META_API_VERSION is intentionally required for live mode so an obsolete
# Graph API version is never silently selected.
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_API_VERSION=

# Optional notification adapter: none, github, webhook
NOTIFICATION_PROVIDER=github
NOTIFICATION_WEBHOOK_URL=
